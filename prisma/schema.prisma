generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String         @id @default(uuid())
  clerkId   String         @unique
  email     String         @unique
  username  String?        @unique
  avatarUrl String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  bookmarks Bookmark[]
  notes     Note[]
  progress  UserProgress[]
  streak       UserStreak?
  dailyTargets DailyTarget[]
  customSheets CustomSheet[]

  @@index([clerkId])
}

model UserProgress {
  id           String        @id @default(uuid())
  userId       String
  problemSlug  String
  status       ProblemStatus
  solvedAt     DateTime?
  attemptCount Int           @default(0)
  reviewCount  Int           @default(0)
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug])
  @@index([userId, status])
}

model Bookmark {
  id          String   @id @default(uuid())
  userId      String
  problemSlug String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug])
  @@index([userId])
}

model Note {
  id          String   @id @default(uuid())
  userId      String
  problemSlug String
  content     String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug])
  @@index([userId])
}

model UserStreak {
  id             String    @id @default(uuid())
  userId         String    @unique
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime? @db.Date
  totalSolved    Int       @default(0)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProblemStatus {
  ATTEMPTED
  SOLVED
  REVISIT
}

model DailyTarget {
  id        String               @id @default(uuid())
  userId    String
  date      String
  note      String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems  DailyTargetProblem[]

  @@unique([userId, date])
  @@index([userId])
}

model DailyTargetProblem {
  id            String      @id @default(uuid())
  dailyTargetId String
  problemSlug   String
  note          String?
  order         Int         @default(0)
  dailyTarget   DailyTarget @relation(fields: [dailyTargetId], references: [id], onDelete: Cascade)

  @@index([dailyTargetId])
}

model CustomSheet {
  id          String              @id @default(uuid())
  userId      String
  title       String
  description String?
  slug        String
  isPublic    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems    CustomSheetProblem[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([isPublic])
}

model CustomSheetProblem {
  id            String      @id @default(uuid())
  customSheetId String
  problemSlug   String
  note          String?
  order         Int         @default(0)
  customSheet   CustomSheet @relation(fields: [customSheetId], references: [id], onDelete: Cascade)

  @@unique([customSheetId, problemSlug])
  @@index([customSheetId])
}
